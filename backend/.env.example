# ==============================================================================
# YGB Backend Environment Variables Template
# ==============================================================================
# Copy this file to '.env' in the same directory and update the values as needed.
# In Dokploy, set these as application environment variables (not as a file).

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ------------------------------------------------------------------------------
# CORS — required for browser requests from the Vercel frontend
# ------------------------------------------------------------------------------
# Comma-separated list of allowed browser origins (no trailing slashes).
# Spring accepts origin patterns, so Vercel preview URLs can use a wildcard.
#
# Required in production:
#   https://ygb-gules.vercel.app          — Vercel production frontend
#   https://*.vercel.app                  — Vercel preview deployments (PR branches)
#
# Add when you attach custom domains to the frontend:
#   https://www.ygb.slogbaa.org
#   https://ygb.slogbaa.org
#
# Local frontend development (optional on VPS; useful if you run Vite locally):
#   http://localhost:5173
#   http://127.0.0.1:5173
#
CORS_ALLOWED_ORIGINS=https://ygb-gules.vercel.app,https://*.vercel.app,https://www.ygb.slogbaa.org,http://localhost:5173

# ------------------------------------------------------------------------------
# Database Configuration (Spring Boot)
# ------------------------------------------------------------------------------
# Local docker-compose: jdbc:postgresql://localhost:5432/ygb_db
# Dokploy (same compose project): jdbc:postgresql://db:5432/ygb_db
# Dokploy (managed Postgres service): jdbc:postgresql://<service-host>:5432/ygb_db
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ygb_db
SPRING_DATASOURCE_USERNAME=ygb_user
SPRING_DATASOURCE_PASSWORD=password

# ------------------------------------------------------------------------------
# PostgreSQL Container Configuration (for Docker Compose)
# ------------------------------------------------------------------------------
# Used when running the database service via docker-compose
POSTGRES_DB=ygb_db
POSTGRES_USER=ygb_user
POSTGRES_PASSWORD=password

# ------------------------------------------------------------------------------
# Security (JWT) Configuration
# ------------------------------------------------------------------------------
# The JWT secret key must be at least 256 bits (32 bytes) long for HS256 algorithm
APP_JWT_SECRET=defaultSecretKeyWithAtLeast32CharactersForHmacSha256
# Token expiration time in milliseconds (e.g., 86400000 ms = 24 hours)
APP_JWT_EXPIRATION_MS=86400000
