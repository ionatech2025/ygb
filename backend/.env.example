# ==============================================================================
# YGB Backend Environment Variables Template
# ==============================================================================
# Copy this file to '.env' in the same directory and update the values as needed.

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
CORS_ALLOWED_ORIGINS=https://ygb-gules.vercel.app,<https://www.ygb.slogbaa.org>

# ------------------------------------------------------------------------------
# Database Configuration (Spring Boot)
# ------------------------------------------------------------------------------
# These variables will automatically bind to spring.datasource.* properties
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ygb_db
SPRING_DATASOURCE_USERNAME=ygb_user
SPRING_DATASOURCE_PASSWORD=password

# ------------------------------------------------------------------------------
# PostgreSQL Container Configuration (for Docker Compose)
# ------------------------------------------------------------------------------
# Used when running the database service via docker-compose
POSTGRES_DB=ygb_db
POSTGRES_USER=ygb_user
POSTGRES_PASSWORD=password

# ------------------------------------------------------------------------------
# Security (JWT) Configuration
# ------------------------------------------------------------------------------
# The JWT secret key must be at least 256 bits (32 bytes) long for HS256 algorithm
APP_JWT_SECRET=defaultSecretKeyWithAtLeast32CharactersForHmacSha256
# Token expiration time in milliseconds (e.g., 86400000 ms = 24 hours)
APP_JWT_EXPIRATION_MS=86400000
