# 2. Database Schema (PostgreSQL DDL)

*One table per aggregate/entity identified in Section 1. UUID primary keys throughout; JSONB used for multi-select and nested per-financial-year data to avoid excessive join tables while keeping the schema stable for new form questions (NFR 5.5). The partial unique index on submissions enforces UNIQ-01/02/03 at the database level as a final safety net behind the application-level checks.*

**users** *[Identity & Access]*

```sql
CREATE TABLE users (
    user_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    full_name VARCHAR(150) NOT NULL,
    phone_number VARCHAR(15) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL,
    role VARCHAR(20) NOT NULL
        CHECK (role IN ('ADMIN','DATA_COLLECTOR')),
    is_active BOOLEAN NOT NULL DEFAULT TRUE,
    created_by_admin_id UUID NULL REFERENCES users(user_id),
    created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_users_role_active ON users(role, is_active);
```

**refresh_tokens** *[Identity & Access]*

```sql
CREATE TABLE refresh_tokens (
    token_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(user_id) ON DELETE CASCADE,
    token_hash VARCHAR(255) NOT NULL,
    expires_at TIMESTAMPTZ NOT NULL,
    revoked BOOLEAN NOT NULL DEFAULT FALSE,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX idx_refresh_tokens_user ON refresh_tokens(user_id);
```

**districts / sub_counties / parishes / villages** *[Location Reference Data]*

```sql
CREATE TABLE districts (
    district_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(100) NOT NULL,
    region VARCHAR(100)
);

CREATE TABLE sub_counties (
    sub_county_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(100) NOT NULL,
    district_id UUID NOT NULL REFERENCES districts(district_id)
);

CREATE INDEX idx_subcounty_district ON sub_counties(district_id);

CREATE TABLE parishes (
    parish_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(100) NOT NULL,
    sub_county_id UUID NOT NULL REFERENCES sub_counties(sub_county_id)
);

CREATE INDEX idx_parish_subcounty ON parishes(sub_county_id);

CREATE TABLE villages (
    village_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(100) NOT NULL,
    parish_id UUID NOT NULL REFERENCES parishes(parish_id)
);

CREATE INDEX idx_village_parish ON villages(parish_id);
```

**submissions** *[PDM Field Data Collection (aggregate root)]*

```sql
CREATE TABLE submissions (
    submission_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    submitted_by UUID NOT NULL REFERENCES users(user_id),
    form_type VARCHAR(20) NOT NULL
        CHECK (form_type IN ('BYP','IYP','LGO','PARISH_MONITORING')),
    respondent_phone VARCHAR(15) NOT NULL, -- denormalised for uniqueness index performance
    financial_year_period VARCHAR(9) NOT NULL, -- e.g. '2026-H1'
    status VARCHAR(12) NOT NULL DEFAULT 'PENDING'
        CHECK (status IN ('PENDING','SYNCED','FLAGGED','DUPLICATE')),
    district_id UUID REFERENCES districts(district_id),
    sub_county_id UUID REFERENCES sub_counties(sub_county_id),
    parish_id UUID REFERENCES parishes(parish_id),
    village_id UUID REFERENCES villages(village_id),
    device_submission_id VARCHAR(64) NOT NULL UNIQUE, -- client idempotency key
    submitted_at TIMESTAMPTZ NOT NULL,
    synced_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- UNIQ-01/02/03: one non-duplicate submission per respondent phone + form type + FY period
CREATE UNIQUE INDEX uniq_respondent_form_period
    ON submissions (respondent_phone, form_type, financial_year_period)
    WHERE status IN ('PENDING','SYNCED');

CREATE INDEX idx_submissions_filters
    ON submissions (form_type, district_id, financial_year_period, status);

CREATE INDEX idx_submissions_collector ON submissions(submitted_by);
CREATE INDEX idx_submissions_submitted_at ON submissions(submitted_at);
```

