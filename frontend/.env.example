# Backend API base URL (required for Vercel production/preview builds).
# Must match the public HTTPS URL of the backend deployed on Dokploy/VPS.
# Without this, the SPA calls /api/* on the Vercel host and the dashboard stays blank.
#
# Example: https://api.ygb.slogbaa.org
# No trailing slash. See docs/deployment-backend-dokploy.md for full setup.
VITE_API_BASE_URL=
